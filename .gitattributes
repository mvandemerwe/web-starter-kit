# Auto-detect text files and normalize line endings
* text=auto

# Explicitly declare text files
*.md text diff=markdown
*.txt text
*.csv text
*.json text
*.xml text
*.yml text
*.yaml text

# Declare binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.zip binary
*.gz binary
*.tar binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
